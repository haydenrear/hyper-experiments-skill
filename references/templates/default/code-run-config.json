{
  "experiment_id": "{{experiment_id}}",
  "slug": "{{slug}}",
  "family": "{{family}}",
  "variant": "default",
  "run_name": "{{experiment_id}}-{{slug}}",
  "parent_experiment": "{{parent_experiment}}",
  "parent_checkpoint": "{{parent_checkpoint}}",
  "paths": {
    "tensorboard": "../tensorboard",
    "checkpoints": "../checkpoints",
    "logs": "../logs",
    "data": "../data",
    "trace_artifact": "../artifacts/trace.json"
  },
  "observability": {
    "service_name": "{{experiment_id}}-{{slug}}",
    "service_version": "0.1.0",
    "log_mode": "otlp-only",
    "flush_timeout_millis": 5000
  },
  "logging": {
    "tensorboard": {
      "flush_secs": 30,
      "max_queue": 100
    },
    "wandb": {
      "run_name": "{{experiment_id}}-{{slug}}",
      "tags": ["{{family}}"]
    }
  },
  "hyperparameters": {}
}
